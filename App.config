	<connectionStrings>
		<add name="dbConnectionString" connectionString="server=localhost;port=3306;database=prsdb;uid=root;password=;" providerName="MySql.Data.MySqlClient" />
		<add name="Patrient_Record.Properties.Settings.prsdbConnectionString" connectionString="Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|\prsdb.mdf;Integrated Security=True;Connect Timeout=30" providerName="System.Data.SqlClient" />
	</connectionStrings>

	<!-- Inserted Vonage (Nexmo) API credentials -->
	<appSettings>
		<add key="VonageApiKey" value="41ab86ee" />
		<add key="VonageApiSecret" value="QeXL330qp3w3lAbB" />
	</appSettings>

	<configBuilders>
